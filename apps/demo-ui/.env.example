# Default local demo mode.
# Copy this file to .env.local if you want to override committed .env settings.
#
# Available values:
#   google - UI uses Google ID token and sends Authorization: Bearer <token>
#   demo   - UI does not send Authorization header; backend must run with demo/dev auth
VITE_AUTH_MODE=demo

# Public OAuth Client ID for browser demo.
# Not a secret. Must match booking-service JWT audience in Google auth mode.
VITE_GOOGLE_CLIENT_ID=683052581411-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com

VITE_BOOKING_SERVICE_BASE_URL=/booking-api
VITE_INVENTORY_SERVICE_BASE_URL=/inventory-api
VITE_AUDIT_SERVICE_BASE_URL=/audit-api